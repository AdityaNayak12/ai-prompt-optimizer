{
  "openapi": "3.1.0",
  "info": {
    "title": "Prompt Advisor API",
    "description": "Backend service for optimization of AI prompts via Groq models.",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health Check",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Health Check Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/optimize": {
      "post": {
        "tags": [
          "optimize"
        ],
        "summary": "Optimize prompt",
        "description": "Analyze a raw prompt and return an improved version based on prompt engineering standards.",
        "operationId": "optimize_api_v1_optimize_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OptimizeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OptimizeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetailResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetailResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DetailResponse": {
        "properties": {
          "detail": {
            "type": "string",
            "title": "Detail",
            "description": "A description of the error."
          }
        },
        "type": "object",
        "required": [
          "detail"
        ],
        "title": "DetailResponse"
      },
      "OptimizeMetrics": {
        "properties": {
          "tokens_before": {
            "type": "integer",
            "title": "Tokens Before",
            "description": "Estimated token count of original prompt."
          },
          "tokens_after": {
            "type": "integer",
            "title": "Tokens After",
            "description": "Estimated token count of optimized prompt."
          },
          "processing_time_ms": {
            "type": "number",
            "title": "Processing Time Ms",
            "description": "FastAPI/Groq API server processing time in milliseconds."
          }
        },
        "type": "object",
        "required": [
          "tokens_before",
          "tokens_after",
          "processing_time_ms"
        ],
        "title": "OptimizeMetrics"
      },
      "OptimizeRequest": {
        "properties": {
          "prompt": {
            "type": "string",
            "minLength": 3,
            "title": "Prompt",
            "description": "The raw, unoptimized prompt to improve.",
            "examples": [
              "How do I write a web server in FastAPI?"
            ]
          },
          "tone": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tone",
            "description": "The desired tone for the response generated by the optimized prompt.",
            "default": "professional",
            "examples": [
              "professional",
              "conversational",
              "academic",
              "concise",
              "creative"
            ]
          },
          "detail_level": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail Level",
            "description": "The depth of detail expected in the response.",
            "default": "balanced",
            "examples": [
              "concise",
              "balanced",
              "detailed"
            ]
          },
          "target_audience": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Target Audience",
            "description": "Who the final response is intended for (e.g. developers, students, executives).",
            "examples": [
              "developers"
            ]
          },
          "groq_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Groq Model",
            "description": "The Groq LLM model used to perform the prompt optimization.",
            "default": "llama3-8b-8192",
            "examples": [
              "llama3-8b-8192",
              "llama3-70b-8192",
              "mixtral-8x7b-32768"
            ]
          }
        },
        "type": "object",
        "required": [
          "prompt"
        ],
        "title": "OptimizeRequest"
      },
      "OptimizeResponse": {
        "properties": {
          "raw_prompt": {
            "type": "string",
            "title": "Raw Prompt",
            "description": "The original prompt input."
          },
          "optimized_prompt": {
            "type": "string",
            "title": "Optimized Prompt",
            "description": "The fully optimized prompt, ready to use."
          },
          "explanation": {
            "type": "string",
            "title": "Explanation",
            "description": "Markdown list explaining what changes were made and why."
          },
          "metrics": {
            "$ref": "#/components/schemas/OptimizeMetrics",
            "description": "Performance and token count metrics."
          }
        },
        "type": "object",
        "required": [
          "raw_prompt",
          "optimized_prompt",
          "explanation",
          "metrics"
        ],
        "title": "OptimizeResponse"
      }
    }
  }
}
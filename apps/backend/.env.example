# Backend Server Configuration
HOST=127.0.0.1
PORT=8000
ENV=development

# LLM Provider Keys
# Get your Groq API Key at https://console.groq.com/
GROQ_API_KEY=gsk_your_api_key_here

# Security Settings
# In production, specify your extension id(s) to secure CORS
# CORS_ORIGINS=["chrome-extension://ipoppdkmflhggmdjkhifghlkpjefplbi"]
CORS_ORIGINS=["*"]
